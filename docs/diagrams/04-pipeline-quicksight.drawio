        <mxCell id="catalog" value="Glue Data Catalog&#10;DB: zammad_sla_db&#10;&#10;Tablas descubiertas:&#10;• tickets&#10;• ticket_timeline&#10;• summary&#10;• by_agent&#10;• by_organization&#10;• by_type&#10;• metadata" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;align=left;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="940" y="300" width="240" height="180" as="geometry" />
