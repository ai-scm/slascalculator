        <mxCell id="iam-crawler" value="IAM Role Crawler&#10;AWSGlueServiceRole&#10;+ S3 Read" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#C7131F;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;html=1;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.identity_and_access_management_iam;labelBackgroundColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="1010" y="550" width="78" height="78" as="geometry" />
        </mxCell>

        <!-- Stage 5: Consumo -->
        <mxCell id="stage5" value="5. Consumo &amp; visualizacion" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1240" y="100" width="230" height="720" as="geometry" />
